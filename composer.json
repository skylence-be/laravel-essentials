{
    "name": "skylence/essentials",
    "description": "Meta-package with essential Laravel dev tooling",
    "keywords": ["laravel", "essentials", "meta-package", "dev-tools"],
    "license": "MIT",
    "authors": [
        {
            "name": "Jonas Vanderhaegen",
            "email": "jonas@skylence.be"
        }
    ],
    "require": {
        "php": "^8.3",
        "nunomaduro/essentials": "^0.1",
        "spatie/laravel-backup": "^9.0 || ^10.0",
        "spatie/laravel-health": "^1.31",
        "spatie/laravel-model-states": "^2.12",
        "spatie/laravel-permission": "^6.24 || ^7.0",
        "spatie/laravel-query-builder": "^6.0"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.27",
        "captainhook/hook-installer": "^5.0",
        "laravel/boost": "^2.1",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-arch": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "pestphp/pest-plugin-type-coverage": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}
